generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER      // Akses penuh: semua laporan keuangan, profit, manajemen user & karyawan
  ADMIN      // Akses POS penuh + laporan keuangan, TIDAK bisa kelola karyawan
  PENGAWAS   // Hanya: input pengeluaran & update status proyek, tanpa laporan keuangan
}

// ─── Enum POS ────────────────────────────────────────────────────────────────

enum ServiceUnit {
  PER_M2      // Bangun / Renovasi
  PER_PAKET   // Desain Arsitektur
  PER_TITIK   // Tes Tanah / Sondir
}

enum ProjectStatus {
  DRAFT
  AKTIF
  SELESAI
  BATAL
}

enum TerminStatus {
  BELUM_DITAGIH
  MENUNGGU_PEMBAYARAN
  LUNAS
}

enum ExpenseCategory {
  MATERIAL
  TUKANG
  OPERASIONAL
  LAINNYA
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  projects  Project[]

  @@map("users")
}

model Profile {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  fotoProfil String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── POS Models ──────────────────────────────────────────────────────────────

/// Katalog jenis layanan yang ditawarkan
model ServiceCatalog {
  id           String      @id @default(uuid()) @db.Uuid
  nama         String
  deskripsi    String?
  satuan       ServiceUnit
  hargaDefault Decimal     @db.Decimal(15, 2)
  aktif        Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  contractItems ContractItem[]

  @@map("services")
}

/// Data pelanggan
model Customer {
  id            String   @id @default(uuid()) @db.Uuid
  nama          String
  noWa          String
  alamat        String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects Project[]

  @@map("customers")
}

/// Proyek / transaksi utama
model Project {
  id            String        @id @default(uuid()) @db.Uuid
  projectId     String        @unique
  customerId    String        @db.Uuid
  createdById   String        @db.Uuid
  namaProyek    String
  alamatProyek  String
  status        ProjectStatus @default(DRAFT)
  progress      Int           @default(0)
  publicToken   String?       @unique // token untuk portal klien
  catatan       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer    Customer      @relation(fields: [customerId], references: [id])
  createdBy   User          @relation(fields: [createdById], references: [id])
  contract    Contract?
  attachments ProjectAttachment[]
  penugasan   PenugasanProyek[]
  upah        CatatanUpah[]

  @@map("projects")
}

/// File lampiran proyek (PDF denah / foto lokasi)
model ProjectAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  namaFile  String
  url       String
  tipe      String   // "pdf" | "image" | "document"
  ukuran    Int      @default(0)
  kategori  String   @default("LAINNYA") // "RAB" | "DESAIN" | "SONDIR" | "FOTO" | "KONTRAK" | "LAINNYA"
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_attachments")
}

/// Kontrak proyek — satu proyek satu kontrak
model Contract {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @unique @db.Uuid
  nilaiKontrak  Decimal  @db.Decimal(15, 2)
  tanggalMulai  DateTime?
  tanggalSelesai DateTime?
  catatan       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items         ContractItem[]
  termins       PaymentTerm[]
  expenses      Expense[]

  @@map("contracts")
}

/// Rincian item jasa dalam kontrak
model ContractItem {
  id          String   @id @default(uuid()) @db.Uuid
  contractId  String   @db.Uuid
  serviceId   String   @db.Uuid
  deskripsi   String?
  volume      Decimal  @db.Decimal(10, 2)
  hargaSatuan Decimal  @db.Decimal(15, 2)
  subtotal    Decimal  @db.Decimal(15, 2)

  contract Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  service  ServiceCatalog @relation(fields: [serviceId], references: [id])

  @@map("contract_items")
}

/// Termin pembayaran
model PaymentTerm {
  id                 String       @id @default(uuid()) @db.Uuid
  contractId         String       @db.Uuid
  namaTermin         String
  persentase         Decimal      @db.Decimal(5, 2)
  jumlah             Decimal      @db.Decimal(15, 2)
  status             TerminStatus @default(BELUM_DITAGIH)
  tanggalJatuhTempo  DateTime?
  tanggalTagih       DateTime?
  tanggalBayar       DateTime?
  catatan            String?
  reminderSent       Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("payment_terms")
}

/// Biaya operasional proyek (material / tukang)
model Expense {
  id         String          @id @default(uuid()) @db.Uuid
  contractId String          @db.Uuid
  kategori   ExpenseCategory
  deskripsi  String
  jumlah     Decimal         @db.Decimal(15, 2)
  tanggal    DateTime        @default(now())
  createdAt  DateTime        @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ─── HR Models ───────────────────────────────────────────────────────────────

enum JabatanKaryawan {
  MANDOR
  TUKANG
  KENEK
  DESAINER
  SURVEYOR
  ADMIN_KANTOR
  LAINNYA
}

enum StatusKaryawan {
  AKTIF
  NONAKTIF
}

enum StatusUpah {
  BELUM_DIBAYAR
  SUDAH_DIBAYAR
}

/// Data karyawan perusahaan
model Karyawan {
  id          String          @id @default(uuid()) @db.Uuid
  nama        String
  nik         String?         @unique
  jabatan     JabatanKaryawan
  noHp        String?
  alamat      String?
  gajiPokok   Decimal?        @db.Decimal(15, 2)
  tanggalMasuk DateTime?
  status      StatusKaryawan  @default(AKTIF)
  catatan     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  penugasan   PenugasanProyek[]
  upah        CatatanUpah[]

  @@map("karyawan")
}

/// Penugasan karyawan ke proyek
model PenugasanProyek {
  id          String   @id @default(uuid()) @db.Uuid
  karyawanId  String   @db.Uuid
  projectId   String   @db.Uuid
  peran       String?  // e.g. "Mandor Utama", "Tukang Besi"
  tanggalMulai DateTime?
  tanggalSelesai DateTime?
  catatan     String?
  createdAt   DateTime @default(now())

  karyawan Karyawan @relation(fields: [karyawanId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("penugasan_proyek")
}

/// Catatan upah harian/mingguan karyawan per proyek
model CatatanUpah {
  id          String     @id @default(uuid()) @db.Uuid
  karyawanId  String     @db.Uuid
  projectId   String?    @db.Uuid
  periode     String     // e.g. "Minggu 1 - Juni 2026"
  jumlahHari  Int        @default(1)
  upahPerHari Decimal    @db.Decimal(15, 2)
  totalUpah   Decimal    @db.Decimal(15, 2)
  status      StatusUpah @default(BELUM_DIBAYAR)
  tanggalBayar DateTime?
  catatan     String?
  createdAt   DateTime   @default(now())

  karyawan Karyawan @relation(fields: [karyawanId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id])

  @@map("catatan_upah")
}
